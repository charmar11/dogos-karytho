{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    
    "presence": {
      "$sessionId": {
        ".write": "auth != null"
      }
    },
    
    "activity_log": {
      ".read": "auth != null && auth.token.role == 'admin'",
      ".write": "auth != null",
      ".indexOn": ["ts"]
    },
    
    "cidop_members": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    
    "sucursales": {
      "$branchId": {
        ".read": "auth != null",
        ".write": "auth != null",
        
        "products": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "sales": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["timestamp", "date"]
        },
        
        "gastos": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "gasto_cats": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "ingredients": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "recipes": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "general_recipe": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "inv_history": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["ts"]
        },
        
        "ing_categories": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "cortes": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["ts"]
        },
        
        "fondo": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        
        "config": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
